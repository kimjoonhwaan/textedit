# OpenAI (기존)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Langsmith (옵션)
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=StMarkdownEditor

# Server
PORT=3001

# Google OAuth (다중 사용자 + Google Drive 통합)
# Google Cloud Console에서 OAuth 2.0 Web application 클라이언트 발급 후 입력
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 로컬: http://localhost:3001/auth/google/callback
# Railway: https://<앱명>.up.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# 세션 암호화 키. 32바이트 hex (openssl rand -hex 32 또는 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=
